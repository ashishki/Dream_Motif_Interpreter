[Unit]
Description=Dream Motif Interpreter API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/srv/openclaw-you/workspace/Dream_Motif_Interpreter
EnvironmentFile=/srv/openclaw-you/workspace/Dream_Motif_Interpreter/.env
ExecStart=/srv/openclaw-you/workspace/Dream_Motif_Interpreter/.venv/bin/python -m app.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
